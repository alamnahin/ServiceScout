# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# PayWay Configuration
# For development/testing, leave USE_MOCK_PAYWAY=true to use mock payment responses
VITE_USE_MOCK_PAYWAY=true

# PayWay Publishable Key (for the client-side card frame)
VITE_PAYWAY_PUBLISHABLE_KEY=your_payway_publishable_key

# PayWay Server Configuration (for production with real payments)
# Set these in Supabase project settings for Edge Functions
PAYWAY_API_URL=https://api.payway.com.au
PAYWAY_MERCHANT_ID=your_merchant_id
PAYWAY_RSA_PUBLIC_KEY=your_rsa_public_key
PAYWAY_RETURN_URL=https://yoursite.com/payment/return
PAYWAY_CANCEL_URL=https://yoursite.com/payment/cancel
